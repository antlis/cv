---
//
//  AnimatedBackground.astro
//  CV Hub
//
//  CSS-only animated background. Drop into Layout.astro instead of body gradient.
//  No JS. Uses CSS @keyframes + custom properties from active theme.
//
//  Created by Alexander Gusarov on 06.03.2026.
//  @spartan121
//
---

<div class="bg" aria-hidden="true">
  <div class="orb orb--1"></div>
  <div class="orb orb--2"></div>
  <div class="orb orb--3"></div>
  <div class="orb orb--4"></div>
  <div class="noise"></div>
</div>

<style>
  .bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: var(--bg);
  }

  /* ── Orbs ── */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.55;
    will-change: transform;
  }

  .orb--1 {
    width: 600px;
    height: 600px;
    top: -15%;
    left: -10%;
    background: radial-gradient(circle, rgba(var(--accent-rgb) / 0.55), transparent 70%);
    animation: drift-1 18s ease-in-out infinite alternate;
  }

  .orb--2 {
    width: 500px;
    height: 500px;
    top: -5%;
    right: -8%;
    background: radial-gradient(circle, rgba(var(--accent-2-rgb) / 0.45), transparent 70%);
    animation: drift-2 22s ease-in-out infinite alternate;
  }

  .orb--3 {
    width: 400px;
    height: 400px;
    bottom: 5%;
    left: 30%;
    background: radial-gradient(circle, rgba(var(--accent-rgb) / 0.30), transparent 70%);
    animation: drift-3 20s ease-in-out infinite alternate;
  }

  .orb--4 {
    width: 300px;
    height: 300px;
    bottom: 20%;
    right: 15%;
    background: radial-gradient(circle, rgba(var(--accent-2-rgb) / 0.25), transparent 70%);
    animation: drift-4 16s ease-in-out infinite alternate;
  }

  /* ── Noise overlay ── */
  .noise {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* ── Keyframes ──
     translate-only (no scale): the browser caches the blurred texture and just
     moves it, instead of re-rasterizing the 60px blur every frame. */
  @keyframes drift-1 {
    0%   { transform: translate(0px,   0px);  }
    33%  { transform: translate(60px,  40px); }
    66%  { transform: translate(20px,  80px); }
    100% { transform: translate(80px,  20px); }
  }

  @keyframes drift-2 {
    0%   { transform: translate(0px,    0px);  }
    33%  { transform: translate(-50px,  60px); }
    66%  { transform: translate(-20px,  30px); }
    100% { transform: translate(-70px,  10px); }
  }

  @keyframes drift-3 {
    0%   { transform: translate(0px,   0px);   }
    33%  { transform: translate(-40px, -50px); }
    66%  { transform: translate(30px,  -20px); }
    100% { transform: translate(-60px, -40px); }
  }

  @keyframes drift-4 {
    0%   { transform: translate(0px,  0px);   }
    33%  { transform: translate(40px, -60px); }
    66%  { transform: translate(10px, -30px); }
    100% { transform: translate(50px, -50px); }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .orb { animation: none; }
  }

  /* ── Disable orbs on small screens ── */
  @media (max-width: 768px) {
    .orb,
    .noise {
      animation: none !important; 
      filter: none !important;    
      opacity: 0 !important;
      display: none;
    }
  }
</style>
